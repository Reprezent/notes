# =============================================================================
# Minimum release age
# =============================================================================
# Only install package versions that have been published for at least 7 days.
# Helps protect against recently-published malicious or broken packages.
# Use min-release-age-exclude[] to exempt trusted internal packages.
min-release-age=7

# =============================================================================
# Install scripts — require manual approval
# =============================================================================
# Prevents pre/post install scripts (preinstall, install, postinstall, etc.)
# from running automatically during `npm install`.
# To approve scripts for a package: npm approve-scripts <pkg>
# To deny scripts for a package:    npm deny-scripts <pkg>
ignore-scripts=true

# =============================================================================
# Auditing
# =============================================================================
audit=true
audit-level=moderate
