{
  "name": "notes",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "npm run lint && expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "web": "expo start --web",
    "preview:web": "node scripts/preview-web.cjs",
    "tracer:build": "cargo xtask build-all",
    "tracer:build:android": "cargo xtask build-android",
    "tracer:build:web": "cargo xtask build-web",
    "tracer:verify": "cargo xtask verify-artifacts",
    "tracer:verify:web": "cargo xtask verify-web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "@shopify/react-native-skia": "^2.6.9",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "~57.0.4",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.1",
    "nativewind": "^4.2.6",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "^0.86.0",
    "react-native-calendars": "^1.1313.0",
    "react-native-logs": "^5.5.0",
    "react-native-reanimated": "^4.5.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.10.1",
    "react-native-worklets-core": "^1.6.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@eslint/compat": "^2.1.0",
    "@types/react": "~19.2.4",
    "eslint": "^10.6.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.4.5",
    "prettier": "^3.9.4",
    "typescript": "~6.0.3"
  },
  "main": "node_modules/expo/AppEntry.js",
  "expo": {
    "autolinking": {
      "searchPaths": [
        "./modules"
      ]
    }
  },
  "private": true
}
